{% comment %}
  Hero Landing Section
  Fully configurable via the theme editor (mimics what you'd build in
  GemPages/PageFly, but native Liquid — no app dependency, no monthly fee).
  Supports unlimited stacked blocks so it can act as a full landing page
  builder section (headline, subtext, image, CTA button, trust badges).
{% endcomment %}

<section
  class="hero-landing hero-landing--{{ section.settings.layout }}"
  style="
    --hero-bg: {{ section.settings.background_color }};
    --hero-text: {{ section.settings.text_color }};
    --hero-overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
  "
>
  {% if section.settings.image %}
    <div class="hero-landing__media">
      {{ section.settings.image | image_url: width: 1800 | image_tag:
        loading: 'eager',
        fetchpriority: 'high',
        widths: '480,768,1024,1440,1800',
        sizes: '100vw',
        class: 'hero-landing__image'
      }}
      <div class="hero-landing__overlay"></div>
    </div>
  {% endif %}

  <div class="hero-landing__content page-width">
    {% for block in section.blocks %}
      {% case block.type %}
        {% when 'heading' %}
          <h1 class="hero-landing__heading" {{ block.shopify_attributes }}>
            {{ block.settings.heading }}
          </h1>

        {% when 'text' %}
          <div class="hero-landing__text" {{ block.shopify_attributes }}>
            {{ block.settings.text }}
          </div>

        {% when 'button' %}
          <div class="hero-landing__cta" {{ block.shopify_attributes }}>
            <a
              href="{{ block.settings.button_link | default: '#' }}"
              class="button button--{{ block.settings.style }}"
            >
              {{ block.settings.button_label }}
            </a>
          </div>

        {% when 'trust_badges' %}
          <ul class="hero-landing__badges" {{ block.shopify_attributes }}>
            {% for i in (1..3) %}
              {% assign badge_key = 'badge_' | append: i %}
              {% assign badge_text = block.settings[badge_key] %}
              {% if badge_text != blank %}
                <li>{{ badge_text }}</li>
              {% endif %}
            {% endfor %}
          </ul>
      {% endcase %}
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Hero Landing",
  "tag": "section",
  "class": "shopify-section--hero-landing",
  "settings": [
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        { "value": "center", "label": "Centered" },
        { "value": "left", "label": "Left aligned" }
      ],
      "default": "center"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Image overlay darkness",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "default": 30
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Fallback background color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    }
  ],
  "blocks": [
    {
      "type": "heading",
      "name": "Heading",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Your Landing Page Headline" }
      ]
    },
    {
      "type": "text",
      "name": "Text",
      "settings": [
        { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Supporting copy that explains the offer.</p>" }
      ]
    },
    {
      "type": "button",
      "name": "Button",
      "settings": [
        { "type": "text", "id": "button_label", "label": "Button label", "default": "Shop Now" },
        { "type": "url", "id": "button_link", "label": "Button link" },
        {
          "type": "select",
          "id": "style",
          "label": "Button style",
          "options": [
            { "value": "primary", "label": "Primary" },
            { "value": "secondary", "label": "Secondary" }
          ],
          "default": "primary"
        }
      ]
    },
    {
      "type": "trust_badges",
      "name": "Trust badges",
      "settings": [
        { "type": "text", "id": "badge_1", "label": "Badge 1", "default": "Free shipping over $50" },
        { "type": "text", "id": "badge_2", "label": "Badge 2", "default": "30-day returns" },
        { "type": "text", "id": "badge_3", "label": "Badge 3", "default": "5-star rated" }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Hero Landing",
      "blocks": [
        { "type": "heading" },
        { "type": "text" },
        { "type": "button" },
        { "type": "trust_badges" }
      ]
    }
  ]
}
{% endschema %}
