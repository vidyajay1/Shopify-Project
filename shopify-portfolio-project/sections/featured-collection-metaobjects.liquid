{% comment %}
  Featured Collection with Metaobject-driven Badges

  Assumes a metaobject definition called "promo_badge" (see
  docs/metafields-metaobjects-setup.md) with fields: label (single line text),
  color (color), icon (file).

  Assumes each product has a metafield:
    namespace: custom
    key: promo_badge
    type: metaobject_reference (reference to promo_badge)

  This is the pattern used to power things like "Best Seller", "Limited
  Restock", or "Editor's Pick" ribbons that merchandisers control without a
  developer touching code — set once in Settings > Metaobjects, then just
  pick the badge on the product from a dropdown.
{% endcomment %}

<section class="featured-collection page-width" id="featured-collection-{{ section.id }}">
  <div class="featured-collection__header">
    <h2>{{ section.settings.heading }}</h2>
    {% if section.settings.subheading != blank %}
      <p class="featured-collection__subheading">{{ section.settings.subheading }}</p>
    {% endif %}
  </div>

  <div class="featured-collection__grid">
    {% assign collection = collections[section.settings.collection] %}
    {% for product in collection.products limit: section.settings.products_to_show %}
      <div class="product-card">
        <a href="{{ product.url }}" class="product-card__link">
          <div class="product-card__media">
            {% if product.featured_image %}
              {{ product.featured_image | image_url: width: 600 | image_tag: loading: 'lazy', widths: '300,450,600', class: 'product-card__image' }}
            {% endif %}

            {%- comment -%} Metaobject-driven badge {%- endcomment -%}
            {% assign badge = product.metafields.custom.promo_badge.value %}
            {% if badge %}
              <span class="product-card__badge" style="background:{{ badge.color.value | default: '#111' }};">
                {{ badge.label.value }}
              </span>
            {% endif %}
          </div>

          <div class="product-card__info">
            <h3 class="product-card__title">{{ product.title }}</h3>
            <span class="product-card__price">{{ product.price | money }}</span>

            {%- comment -%} Simple metafield example: material {%- endcomment -%}
            {% if product.metafields.custom.material != blank %}
              <span class="product-card__meta">{{ product.metafields.custom.material.value }}</span>
            {% endif %}
          </div>
        </a>
      </div>
    {% else %}
      <p>Select a collection in the theme editor to display products here.</p>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Featured Collection (Metaobjects)",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Featured Products" },
    { "type": "text", "id": "subheading", "label": "Subheading" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "products_to_show", "label": "Products to show", "min": 2, "max": 12, "step": 1, "default": 8 }
  ],
  "presets": [
    { "name": "Featured Collection (Metaobjects)" }
  ]
}
{% endschema %}
